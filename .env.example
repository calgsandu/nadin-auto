# SIA e-Factura. Completează URL-urile confirmate de SFS pentru companie.
# Ghidul oficial indică https://api-test.fisc.md/Service.svc pentru test,
# dar domeniul nu răspundea în DNS la 14.07.2026; nu îl folosi în producție.
EFACTURA_WSDL_URL=
EFACTURA_ENDPOINT_URL=
EFACTURA_API_USERNAME=
EFACTURA_API_PASSWORD=

# URL-ul public folosit pentru canonical, hreflang, robots și sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 2FA obligatoriu. Fiecare valoare este un secret aleator de 32 bytes, base64.
TWO_FACTOR_ENCRYPTION_KEY=
TWO_FACTOR_RATE_LIMIT_PEPPER=

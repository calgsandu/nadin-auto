generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppRole {
  ADMIN
  DIRECTOR
  ANGAJAT
}

enum ProductSource {
  EXCEL
  MANUAL
}

enum PartnerKind {
  SUPPLIER
  CUSTOMER
  BOTH
}

enum StockDocumentType {
  RECEIPT
  SALE
  RETURN
  ADJUSTMENT
}

enum RestockTaskStatus {
  PENDING
  DELIVERED
  UNAVAILABLE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  userName  String?
  userEmail String?
  action    AuditAction
  entity    String
  entityId  String?
  summary   String
  details   Json?
  createdAt DateTime    @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}

model AppUser {
  id         String   @id @default(cuid())
  authUserId String   @unique
  username   String?  @unique
  email      String?
  name       String?
  role       AppRole  @default(ANGAJAT)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Brand {
  id        String     @id @default(cuid())
  name      String     @unique
  models    CarModel[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CarModel {
  id        String            @id @default(cuid())
  brandId   String
  name      String
  brand     Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  fitments  VehicleFitment[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([brandId, name])
  @@index([name])
}

model VehicleFitment {
  id            String    @id @default(cuid())
  carModelId    String
  label         String
  yearStart     Int?
  yearEnd       Int?
  yearOpenEnded Boolean   @default(false)
  carModel      CarModel  @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  products      Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([carModelId, label])
  @@index([yearStart, yearEnd])
}

model ProductType {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String         @id @default(cuid())
  importKey   String         @unique
  source      ProductSource  @default(EXCEL)
  manuallyEdited Boolean     @default(false)
  sourceRow   Int
  sourceItem  String?
  externalCode String?
  description String
  notes       String?
  stock       Int?
  /// Prag de alertă stoc minim; null = pragul implicit (3).
  minStock    Int?
  priceEuro     Decimal?     @db.Decimal(10, 2)
  costLei       Decimal?     @db.Decimal(10, 2)
  salePriceLei  Decimal?     @db.Decimal(10, 2)
  fitmentId   String
  typeId      String
  fitment     VehicleFitment @relation(fields: [fitmentId], references: [id], onDelete: Restrict)
  type        ProductType    @relation(fields: [typeId], references: [id], onDelete: Restrict)
  warehouseStocks WarehouseStock[]
  stockLines   StockDocumentLine[]
  restockTasks RestockTask[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([sourceRow])
  @@index([externalCode])
  @@index([description])
  @@index([typeId])
  @@index([fitmentId])
}

model Warehouse {
  id        String            @id @default(cuid())
  name      String            @unique
  isDefault Boolean           @default(false)
  active    Boolean           @default(true)
  stocks    WarehouseStock[]
  documents StockDocument[]
  restockTasks RestockTask[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model WarehouseStock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int       @default(0)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([productId])
}

model Partner {
  id        String          @id @default(cuid())
  name      String          @unique
  kind      PartnerKind     @default(BOTH)
  phone     String?
  notes     String?
  documents StockDocument[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model StockDocument {
  id          String              @id @default(cuid())
  type        StockDocumentType
  number      Int
  documentDate DateTime           @default(now())
  warehouseId String
  partnerId   String?
  /// RETURN: id-ul vânzării sursă. Ține legătura retur↔vânzare.
  sourceDocumentId String?
  /// ADJUSTMENT-transfer: id comun pentru cele două jumătăți (ieșire+intrare).
  transferGroupId  String?
  notes       String?
  totalEuro   Decimal?            @db.Decimal(10, 2)
  totalLei    Decimal?            @db.Decimal(10, 2)
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  partner     Partner?            @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  lines       StockDocumentLine[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([type, number])
  @@index([documentDate])
  @@index([warehouseId])
  @@index([partnerId])
  @@index([sourceDocumentId])
  @@index([transferGroupId])
}

model StockDocumentLine {
  id          String        @id @default(cuid())
  documentId String
  productId  String
  quantity   Int
  unitPriceEuro Decimal?    @db.Decimal(10, 2)
  unitCostLei   Decimal?    @db.Decimal(10, 2)
  document   StockDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product    Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([documentId])
  @@index([productId])
}

model RestockTask {
  id               String            @id @default(cuid())
  productId        String
  warehouseId      String
  sourceDocumentId String?
  quantity         Int
  status           RestockTaskStatus @default(PENDING)
  requestedAt      DateTime          @default(now())
  resolvedAt       DateTime?
  product          Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse        Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([warehouseId, status])
  @@index([productId, status])
  @@index([sourceDocumentId])
  @@index([requestedAt])
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppRole {
  ADMIN
  DIRECTOR
  ANGAJAT
}

enum ProductSource {
  EXCEL
  MANUAL
}

enum PartnerKind {
  SUPPLIER
  CUSTOMER
  BOTH
}

enum StockDocumentType {
  RECEIPT
  SALE
  RETURN
  ADJUSTMENT
}

enum SalePaymentMethod {
  CASH
  CARD
}

enum RestockTaskStatus {
  PENDING
  DELIVERED
  UNAVAILABLE
}

enum PaymentAccountStatus {
  ISSUED
  CANCELLED
}

enum EFacturaSubmissionStatus {
  NOT_SENT
  SUBMITTED
  ERROR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum ReviewStatus {
  PENDING
  APPROVED
  FLAGGED
}

enum PendingOperationKind {
  SALE
  PAYMENT_ACCOUNT_FULFILLMENT
}

enum PendingOperationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TwoFactorCredentialStatus {
  PENDING
  ACTIVE
}

enum TwoFactorRateLimitScope {
  USER_SESSION
  IP
}

/// Fluxul back-to-back: cerere client → ofertă furnizor → comandă → livrare.
enum ExternalOrderStatus {
  CERERE
  OFERTAT
  CONFIRMAT
  RECEPTIONAT
  LIVRAT
  ANULAT
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  userName  String?
  userEmail String?
  action    AuditAction
  entity    String
  entityId  String?
  summary   String
  details   Json?
  createdAt DateTime    @default(now())

  /// Aprobarea directorului: ANGAJAT → PENDING, DIRECTOR/ADMIN → auto-APPROVED.
  reviewStatus   ReviewStatus @default(APPROVED)
  reviewedById   String?
  reviewedByName String?
  reviewedAt     DateTime?
  reviewNote     String?

  @@index([createdAt])
  @@index([entity, entityId])
  @@index([reviewStatus])
}

model PendingOperation {
  id               String                 @id @default(cuid())
  kind             PendingOperationKind
  status           PendingOperationStatus @default(PENDING)
  requestedById    String
  requestedByName  String?
  requestedByEmail String?
  requestedByRole  AppRole
  summary          String
  payload          Json
  activeKey        String?                @unique
  reviewedById     String?
  reviewedByName   String?
  reviewedAt       DateTime?
  reviewNote       String?
  appliedEntityId  String?
  lastError        String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([status, createdAt])
  @@index([kind, status])
  @@index([requestedById, createdAt])
}

model AppUser {
  id                      String                   @id @default(cuid())
  authUserId              String                   @unique
  username                String?                  @unique
  email                   String?
  name                    String?
  role                    AppRole                  @default(ANGAJAT)
  active                  Boolean                  @default(true)
  twoFactorResetAt        DateTime?
  twoFactorCredential      TwoFactorCredential?
  twoFactorEnrollmentGrant TwoFactorEnrollmentGrant?
  twoFactorSessionProofs   TwoFactorSessionProof[]
  trustedDevices          TrustedDevice[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model TwoFactorCredential {
  id               String                    @id @default(cuid())
  appUserId        String                    @unique
  status           TwoFactorCredentialStatus @default(PENDING)
  encryptedSecret  String
  setupExpiresAt   DateTime?
  verifiedAt       DateTime?
  lastAcceptedStep          BigInt?
  enrollmentAuthSessionHash String?
  appUser          AppUser                   @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  sessionProofs    TwoFactorSessionProof[]
  trustedDevices   TrustedDevice[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([status, setupExpiresAt])
}

model TwoFactorEnrollmentGrant {
  id        String   @id @default(cuid())
  appUserId String   @unique
  tokenHash String   @unique
  expiresAt DateTime
  appUser   AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model TwoFactorSessionProof {
  id              String              @id @default(cuid())
  appUserId       String
  credentialId    String
  tokenHash       String              @unique
  authSessionHash String              @unique
  expiresAt       DateTime
  appUser         AppUser             @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  credential      TwoFactorCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  createdAt       DateTime             @default(now())

  @@index([appUserId, expiresAt])
  @@index([credentialId])
}

model TrustedDevice {
  id           String              @id @default(cuid())
  appUserId    String
  credentialId String
  tokenHash    String              @unique
  expiresAt    DateTime
  lastUsedAt   DateTime
  appUser      AppUser             @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  credential   TwoFactorCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now())

  @@index([appUserId, expiresAt])
  @@index([credentialId])
}

model TwoFactorRateLimit {
  id            String                  @id @default(cuid())
  scope         TwoFactorRateLimitScope
  keyHash       String
  failures      Int
  windowStarted DateTime
  blockedUntil  DateTime?
  updatedAt     DateTime                @updatedAt

  @@unique([scope, keyHash])
  @@index([blockedUntil])
  @@index([updatedAt])
}

model Brand {
  id        String     @id @default(cuid())
  name      String     @unique
  models    CarModel[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CarModel {
  id        String            @id @default(cuid())
  brandId   String
  name      String
  brand     Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  fitments  VehicleFitment[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([brandId, name])
  @@index([name])
}

model VehicleFitment {
  id            String    @id @default(cuid())
  carModelId    String
  label         String
  labelRu       String?
  yearStart     Int?
  yearEnd       Int?
  yearOpenEnded Boolean   @default(false)
  carModel      CarModel  @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  products      Product[]
  productFitments ProductFitment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([carModelId, label])
  @@index([yearStart, yearEnd])
}

model ProductType {
  id        String    @id @default(cuid())
  name      String    @unique
  nameRu    String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String         @id @default(cuid())
  importKey   String         @unique
  source      ProductSource  @default(EXCEL)
  manuallyEdited Boolean     @default(false)
  /// Piesă fabricată local (manufactura proprie), nu importată.
  isLocal     Boolean        @default(false)
  sourceRow   Int
  sourceItem  String?
  externalCode String?
  alternativeCode String?
  description String
  descriptionRu String?
  notes       String?
  notesRu     String?
  stock       Int?
  /// Prag de alertă stoc minim; null = pragul implicit (3).
  minStock    Int?
  priceEuro     Decimal?     @db.Decimal(10, 2)
  costLei       Decimal?     @db.Decimal(10, 2)
  salePriceLei  Decimal?     @db.Decimal(10, 2)
  fitmentId   String
  typeId      String
  fitment     VehicleFitment @relation(fields: [fitmentId], references: [id], onDelete: Restrict)
  productFitments ProductFitment[]
  type        ProductType    @relation(fields: [typeId], references: [id], onDelete: Restrict)
  warehouseStocks WarehouseStock[]
  stockLines   StockDocumentLine[]
  restockTasks RestockTask[]
  paymentAccountLines PaymentAccountLine[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([sourceRow])
  @@index([externalCode])
  @@index([description])
  @@index([typeId])
  @@index([fitmentId])
}

model ProductFitment {
  productId String
  fitmentId String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  fitment   VehicleFitment @relation(fields: [fitmentId], references: [id], onDelete: Cascade)

  @@id([productId, fitmentId])
  @@index([fitmentId])
}

model Warehouse {
  id        String            @id @default(cuid())
  name      String            @unique
  isDefault Boolean           @default(false)
  active    Boolean           @default(true)
  stocks    WarehouseStock[]
  documents StockDocument[]
  restockTasks RestockTask[]
  paymentAccounts PaymentAccount[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model WarehouseStock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int       @default(0)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([productId])
}

model Partner {
  id        String          @id @default(cuid())
  name      String          @unique
  kind      PartnerKind     @default(BOTH)
  phone     String?
  email     String?
  address   String?
  idno      String?
  vatCode   String?
  iban      String?
  bankName  String?
  bankCode  String?
  notes     String?
  documents StockDocument[]
  paymentAccounts PaymentAccount[]
  externalOrders ExternalOrder[]
  externalLines StockDocumentLine[] @relation("ExternalLineSupplier")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

/// Comandă la furnizor extern (back-to-back): piesa NU intră în catalog/stoc,
/// dar păstrăm clientul, furnizorul, costul și marja pentru trasabilitate.
model ExternalOrder {
  id       String              @id @default(cuid())
  number   Int                 @unique
  status   ExternalOrderStatus @default(CERERE)

  customerName  String
  customerPhone String?

  productName String
  productCode String?
  quantity    Int     @default(1)

  supplierId String?
  supplier   Partner? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  /// Preț de achiziție per bucată, de la furnizor.
  supplierPriceLei Decimal? @db.Decimal(10, 2)
  /// Preț de vânzare per bucată, către client.
  salePriceLei     Decimal? @db.Decimal(10, 2)
  offerValidUntil  DateTime?

  notes String?

  quotedAt    DateTime?
  confirmedAt DateTime?
  receivedAt  DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([supplierId])
}

model StockDocument {
  id          String              @id @default(cuid())
  type        StockDocumentType
  number      Int
  documentDate DateTime           @default(now())
  warehouseId String
  partnerId   String?
  /// RETURN: id-ul vânzării sursă. Ține legătura retur↔vânzare.
  sourceDocumentId String?
  /// ADJUSTMENT-transfer: id comun pentru cele două jumătăți (ieșire+intrare).
  transferGroupId  String?
  notes       String?
  totalEuro   Decimal?            @db.Decimal(10, 2)
  totalLei    Decimal?            @db.Decimal(10, 2)
  /// SALE: true = bătută în casa de marcat, false = nebătută, null = nespecificat.
  cashRegistered Boolean?
  /// SALE: CASH/CARD; null = vânzare istorică sau nespecificată.
  paymentMethod SalePaymentMethod?
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  partner     Partner?            @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  lines       StockDocumentLine[]
  paymentAccount PaymentAccount? @relation("PaymentAccountSale")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([type, number])
  @@index([documentDate])
  @@index([warehouseId])
  @@index([partnerId])
  @@index([sourceDocumentId])
  @@index([transferGroupId])
}

model PaymentAccount {
  id             String                    @id @default(cuid())
  number         Int                       @unique
  issueDate      DateTime                  @default(now())
  dueDate        DateTime?
  status         PaymentAccountStatus      @default(ISSUED)
  paidAt         DateTime?
  fulfilledAt    DateTime?
  cancelledAt    DateTime?
  warehouseId    String
  partnerId      String
  saleDocumentId String?                   @unique
  notes          String?

  customerName     String
  customerAddress  String
  customerIdno     String
  customerVatCode  String?
  customerPhone    String?
  customerEmail    String?
  customerIban     String?
  customerBankName String?
  customerBankCode String?

  totalNet       Decimal                   @db.Decimal(12, 2)
  totalVat       Decimal                   @db.Decimal(12, 2)
  totalGross     Decimal                   @db.Decimal(12, 2)

  eFacturaStatus       EFacturaSubmissionStatus @default(NOT_SENT)
  eFacturaRequestId    String?
  eFacturaResponseCode Int?
  eFacturaMessage      String?
  eFacturaSubmittedAt  DateTime?

  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  partner         Partner       @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  saleDocument    StockDocument? @relation("PaymentAccountSale", fields: [saleDocumentId], references: [id], onDelete: SetNull)
  lines           PaymentAccountLine[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([issueDate])
  @@index([partnerId])
  @@index([warehouseId])
  @@index([status])
}

model PaymentAccountLine {
  id                String         @id @default(cuid())
  paymentAccountId  String
  productId         String
  productCode       String?
  description       String
  unitOfMeasure     String         @default("buc.")
  quantity          Int
  unitPriceGross    Decimal        @db.Decimal(12, 2)
  unitPriceNet      Decimal        @db.Decimal(12, 2)
  totalNet          Decimal        @db.Decimal(12, 2)
  totalVat          Decimal        @db.Decimal(12, 2)
  totalGross        Decimal        @db.Decimal(12, 2)
  paymentAccount    PaymentAccount @relation(fields: [paymentAccountId], references: [id], onDelete: Cascade)
  product           Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([paymentAccountId])
  @@index([productId])
}

model StockDocumentLine {
  id          String        @id @default(cuid())
  documentId String
  /// null = linie externă (piesă de la furnizor, în afara catalogului propriu).
  productId  String?
  /// Denumirea liberă a piesei externe; setată doar când productId e null.
  externalName String?
  /// Codul piesei externe (ex. codul Polcar/furnizor).
  externalCode String?
  externalSupplierId String?
  quantity   Int
  unitPriceEuro Decimal?    @db.Decimal(10, 2)
  /// Pe linii externe: cost de achiziție per bucată (marja = preț − cost).
  unitCostLei   Decimal?    @db.Decimal(10, 2)
  document   StockDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product    Product?      @relation(fields: [productId], references: [id], onDelete: Restrict)
  externalSupplier Partner? @relation("ExternalLineSupplier", fields: [externalSupplierId], references: [id], onDelete: SetNull)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([documentId])
  @@index([productId])
  @@index([externalSupplierId])
}

model RestockTask {
  id               String            @id @default(cuid())
  productId        String
  warehouseId      String
  sourceDocumentId String?
  quantity         Int
  status           RestockTaskStatus @default(PENDING)
  requestedAt      DateTime          @default(now())
  resolvedAt       DateTime?
  product          Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse        Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([warehouseId, status])
  @@index([productId, status])
  @@index([sourceDocumentId])
  @@index([requestedAt])
}
